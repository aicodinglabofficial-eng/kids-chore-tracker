From 2a17be5218c04f2263dc53f3721a1e047e5892a2 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Tue, 7 Jul 2026 17:23:57 +0000
Subject: [PATCH] Add production single-service build for Fly.io deployment

- Express now serves the built client (client/dist) and falls back to index.html for client-side routes, so the whole app runs as one server process
- DB path is configurable via DATA_DIR env var and the data directory is auto-created, so a mounted persistent volume works out of the box
- Add Dockerfile that builds the client and runs the server together
---
 .dockerignore       |  4 ++++
 Dockerfile          | 22 ++++++++++++++++++++++
 server/src/db.js    |  6 +++++-
 server/src/index.js |  9 +++++++++
 4 files changed, 40 insertions(+), 1 deletion(-)
 create mode 100644 .dockerignore
 create mode 100644 Dockerfile

diff --git a/.dockerignore b/.dockerignore
new file mode 100644
index 0000000..e8113ed
--- /dev/null
+++ b/.dockerignore
@@ -0,0 +1,4 @@
+**/node_modules
+**/dist
+**/data
+.git
diff --git a/Dockerfile b/Dockerfile
new file mode 100644
index 0000000..28732ba
--- /dev/null
+++ b/Dockerfile
@@ -0,0 +1,22 @@
+FROM node:20-slim AS client-build
+WORKDIR /app/client
+COPY client/package*.json ./
+RUN npm ci
+COPY client/ ./
+RUN npm run build
+
+FROM node:20-slim
+RUN apt-get update \
+  && apt-get install -y --no-install-recommends python3 make g++ \
+  && rm -rf /var/lib/apt/lists/*
+WORKDIR /app/server
+COPY server/package*.json ./
+RUN npm ci --omit=dev
+COPY server/ ./
+COPY --from=client-build /app/client/dist /app/client/dist
+
+ENV NODE_ENV=production
+ENV DATA_DIR=/app/server/data
+EXPOSE 4000
+
+CMD ["node", "src/index.js"]
diff --git a/server/src/db.js b/server/src/db.js
index c33cbd0..b7e9e9d 100644
--- a/server/src/db.js
+++ b/server/src/db.js
@@ -1,9 +1,13 @@
 import Database from "better-sqlite3";
+import fs from "node:fs";
 import path from "node:path";
 import { fileURLToPath } from "node:url";
 
 const __dirname = path.dirname(fileURLToPath(import.meta.url));
-const dbPath = path.join(__dirname, "..", "data", "chore-tracker.db");
+const dataDir = process.env.DATA_DIR || path.join(__dirname, "..", "data");
+const dbPath = path.join(dataDir, "chore-tracker.db");
+
+fs.mkdirSync(dataDir, { recursive: true });
 
 export const db = new Database(dbPath);
 db.pragma("journal_mode = WAL");
diff --git a/server/src/index.js b/server/src/index.js
index a4c35bf..84af4e8 100644
--- a/server/src/index.js
+++ b/server/src/index.js
@@ -1,8 +1,11 @@
 import express from "express";
 import cors from "cors";
+import path from "node:path";
+import { fileURLToPath } from "node:url";
 import "./db.js";
 import { router } from "./routes.js";
 
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
 const app = express();
 const PORT = process.env.PORT || 4000;
 
@@ -12,6 +15,12 @@ app.use("/api", router);
 
 app.get("/api/health", (req, res) => res.json({ ok: true }));
 
+const clientDist = path.join(__dirname, "..", "..", "client", "dist");
+app.use(express.static(clientDist));
+app.get(/^(?!\/api).*/, (req, res) => {
+  res.sendFile(path.join(clientDist, "index.html"));
+});
+
 app.listen(PORT, () => {
   console.log(`Kids Chore Tracker API running on http://localhost:${PORT}`);
 });
-- 
